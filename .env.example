# Copy to .env and adjust as needed.

# --- Audit log storage ---------------------------------------------------
# If DATABASE_URL is set, the gateway logs to Postgres (Phase 2+).
# If it is unset, the gateway falls back to SQLite (Phase 1 behaviour) - handy
# for running the tests without Docker.
DATABASE_URL=postgresql://guardrail:guardrail@localhost:5432/guardrail

# SQLite fallback location (used only when DATABASE_URL is unset).
GUARDRAIL_DB_PATH=data/audit.db

# --- Policy --------------------------------------------------------------
# Which policy config the gateway loads.
GUARDRAIL_POLICY_PATH=policy.yaml

# Who the gateway believes is calling ON THE STDIO TRANSPORT ONLY, where it is
# asserted by whoever launches the gateway. The HTTP transport authenticates
# with API keys instead (below).
GUARDRAIL_AGENT_ID=demo-agent
GUARDRAIL_AGENT_ROLE=support-agent

# --- HTTP gateway ---------------------------------------------------------
# Agent API keys: key:agent_id:role, comma-separated. These are DEV examples -
# generate real random keys for anything shared. Keys never go in policy.yaml
# (that file is committed to git; this one is not).
GUARDRAIL_AGENT_KEYS=dev-key-support:support-01:support-agent,dev-key-readonly:reader-01:readonly-agent

# Key for the approve/deny + audit-browsing endpoints. Unset = everything 401s.
GUARDRAIL_ADMIN_KEY=dev-admin-key

# HITL tuning. The approval timeout must be SHORTER than the agent's HTTP read
# timeout, because the tools/call request stays open while a human decides.
GUARDRAIL_APPROVAL_TIMEOUT=120
GUARDRAIL_APPROVAL_POLL_INTERVAL=0.5

GUARDRAIL_HTTP_HOST=127.0.0.1
GUARDRAIL_HTTP_PORT=8000
